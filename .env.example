# ======================================================
# Unified Profile Explorer — Environment Variables
# ======================================================
# Copy this file to .env in the backend directory
# and fill in the values before running the application.

# ------------------
# Database (PostgreSQL)
# ------------------
# Full connection string for PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/unified_profile

# ------------------
# Cache (Redis)
# ------------------
# Full Redis connection URL
REDIS_URL=redis://localhost:6379

# ------------------
# Auth
# ------------------
# JWT signing secret — use a long random string in production
# Generate with: openssl rand -hex 64
JWT_SECRET=change-this-jwt-secret-in-production

# ------------------
# Encryption
# ------------------
# AES-256 encryption key for storing org credentials
# MUST be exactly 32 characters (256 bits)
# Generate with: openssl rand -hex 16
ENCRYPTION_KEY=change-this-32-char-encryption-key!!

# ------------------
# Server
# ------------------
PORT=4000
NODE_ENV=development

# ------------------
# Frontend (Next.js)
# ------------------
# The public URL of the backend API — accessible from the browser
NEXT_PUBLIC_API_URL=http://localhost:4000/api
